# === Plantilla de variables — copiala a .env y completá los valores reales.
# === Los valores reales NO van a Git: se cargan en la UI de Coolify.

# URL pública (el subdominio en el VPS)
POSTIZ_PUBLIC_URL=https://postwiz.wizzi.com.ar
DISABLE_REGISTRATION=true

# Secreto para los JWT. Generá uno largo y aleatorio:
#   openssl rand -hex 32
JWT_SECRET=

# Dejar en false en producción (con HTTPS real detrás de Coolify/Traefik)
NOT_SECURED=false

# === Meta (Facebook + Instagram vía Facebook Login)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# === Instagram standalone (opcional, normalmente vacío)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
